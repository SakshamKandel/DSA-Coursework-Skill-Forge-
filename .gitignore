# Compiled class files
*.class

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.ear

# Allow the MySQL JDBC driver so the project runs out of the box
!WebContent/WEB-INF/lib/mysql-connector-j-*.jar

# Virtual machine crash logs
hs_err_pid*

# Eclipse workspace files (kept .project and .classpath so the project
# can be imported straight into Eclipse without manual setup)
.settings/

# Build and tooling
/bin/
/build/
/target/
/tooling/
